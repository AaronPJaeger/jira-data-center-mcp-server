# Jira Data Center v10 endpoint, without a trailing slash preferred.
JIRA_SERVER_URL=https://your-enterprise-jira-datacenter.com

# Jira Personal Access Token for a user/service account with the required project permissions.
JIRA_PAT=your_secure_personal_access_token_string_here

# Optional: DEBUG, INFO, WARNING, ERROR, or CRITICAL.
LOG_LEVEL=INFO

# Optional tool exposure profile.
# Supported profiles: readonly, standard, agile, admin, full, dangerous.
# Default: standard.
JIRA_MCP_PROFILE=standard

# Optional explicit group override. If set, this takes precedence over JIRA_MCP_PROFILE.
# Example:
# JIRA_MCP_ENABLED_GROUPS=READONLY_CORE,METADATA,WORKFLOW_READ,AGILE_READ
# Available groups:
# READONLY_CORE,METADATA,WORKFLOW_READ,WORKFLOW_WRITE,ISSUE_WRITE,COMMENT_WRITE,
# ASSIGNMENT_WRITE,LINK_WRITE,PROPERTY_WRITE,ATTACHMENT_WRITE,WORKLOG_WRITE,
# AGILE_READ,AGILE_WRITE,ADMIN_READ,ADMIN_WRITE,BULK,DESTRUCTIVE
# JIRA_MCP_ENABLED_GROUPS=
