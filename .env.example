# Jira Data Center v10 endpoint, without a trailing slash preferred.
JIRA_SERVER_URL=https://your-enterprise-jira-datacenter.com

# Jira Personal Access Token for a user/service account with the required project permissions.
JIRA_PAT=your_secure_personal_access_token_string_here

# Optional: DEBUG, INFO, WARNING, ERROR, or CRITICAL.
LOG_LEVEL=INFO
