{
  "mcpServers": {
    "jira-readonly": {
      "type": "stdio",
      "command": "/absolute/path/to/jira-data-center-mcp-server/.venv/bin/python",
      "args": [
        "/absolute/path/to/jira-data-center-mcp-server/jira_server.py"
      ],
      "env": {
        "JIRA_MCP_PROFILE": "readonly"
      }
    },
